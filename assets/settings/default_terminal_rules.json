{
  "_comment": "[官方配置] 此文件由 Bspterm 自动安装和更新，请勿修改。如需自定义规则，请直接在规则编辑器中添加。",
  "version": 4,
  "rules": [
    {
      "id": "00000000-0000-0000-0000-000000000001",
      "name": "Auto Login - Username",
      "enabled": true,
      "trigger": "wakeup",
      "max_triggers": null,
      "condition": {
        "type": "pattern",
        "pattern": "(?i)(username|login|user)\\s*:",
        "case_insensitive": true
      },
      "action": {
        "type": "send_credential",
        "credential_type": "username"
      },
      "exclude_user_input": true
    },
    {
      "id": "00000000-0000-0000-0000-000000000002",
      "name": "Auto Login - Password",
      "enabled": true,
      "trigger": "wakeup",
      "max_triggers": null,
      "condition": {
        "type": "pattern",
        "pattern": "(?i)password\\s*:",
        "case_insensitive": true
      },
      "action": {
        "type": "send_credential",
        "credential_type": "password"
      },
      "exclude_user_input": true,
      "exclude_context": {
        "pattern": "(?i)(bootload|bootrom|boot\\s*menu|ftp)",
        "case_insensitive": true,
        "lines_before": 5
      }
    },
    {
      "id": "00000000-0000-0000-0000-000000000003",
      "name": "SSH Fingerprint Accept",
      "enabled": true,
      "trigger": "wakeup",
      "max_triggers": null,
      "condition": {
        "type": "pattern",
        "pattern": "(?i)continue connecting.*\\(yes/no",
        "case_insensitive": true
      },
      "action": {
        "type": "send_text",
        "text": "yes",
        "append_newline": true
      },
      "exclude_user_input": true
    }
  ]
}
